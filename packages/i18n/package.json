{
  "name": "@pyreon/i18n",
  "version": "0.0.1",
  "description": "Reactive internationalization for Pyreon with async namespace loading",
  "type": "module",
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    },
    "./devtools": {
      "bun": "./src/devtools.ts",
      "import": "./lib/devtools.js",
      "types": "./lib/types/devtools.d.ts"
    }
  },
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@pyreon/core": "^0.2.1",
    "@pyreon/reactivity": "^0.2.1"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.3",
    "@pyreon/core": "^0.2.1",
    "@pyreon/reactivity": "^0.2.1",
    "@pyreon/runtime-dom": "^0.2.1"
  }
}
