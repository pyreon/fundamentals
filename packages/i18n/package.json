{
  "name": "@pyreon/i18n",
  "version": "0.2.0",
  "description": "Reactive internationalization for Pyreon with async namespace loading",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/fundamentals.git",
    "directory": "packages/i18n"
  },
  "homepage": "https://github.com/pyreon/fundamentals/tree/main/packages/i18n#readme",
  "bugs": {
    "url": "https://github.com/pyreon/fundamentals/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    },
    "./devtools": {
      "bun": "./src/devtools.ts",
      "import": "./lib/devtools.js",
      "types": "./lib/types/devtools.d.ts"
    }
  },
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@pyreon/core": "^0.4.0",
    "@pyreon/reactivity": "^0.4.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.3",
    "@pyreon/core": "^0.4.0",
    "@pyreon/reactivity": "^0.4.0",
    "@pyreon/runtime-dom": "^0.4.0"
  }
}
