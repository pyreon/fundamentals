{
  "name": "@pyreon/charts",
  "version": "0.7.0",
  "description": "Reactive ECharts bridge for Pyreon — lazy loading, signal-driven, Canvas by default",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pyreon/fundamentals.git",
    "directory": "packages/charts"
  },
  "homepage": "https://github.com/pyreon/fundamentals/tree/main/packages/charts#readme",
  "bugs": {
    "url": "https://github.com/pyreon/fundamentals/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "type": "module",
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    },
    "./manual": {
      "bun": "./src/manual.ts",
      "import": "./lib/manual.js",
      "types": "./lib/types/manual.d.ts"
    }
  },
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@pyreon/core": ">=0.7.0 <1.0.0",
    "@pyreon/reactivity": ">=0.7.0 <1.0.0",
    "echarts": ">=5.6.0"
  },
  "devDependencies": {
    "@pyreon/core": ">=0.7.0 <1.0.0",
    "@pyreon/reactivity": ">=0.7.0 <1.0.0",
    "@pyreon/runtime-dom": ">=0.7.0 <1.0.0",
    "echarts": "^6.0.0"
  }
}
