{
  "name": "@pyreon/validation",
  "version": "0.0.1",
  "description": "Schema validation adapters for Pyreon forms (Zod, Valibot, ArkType)",
  "type": "module",
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/types/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./lib/index.js",
      "types": "./lib/types/index.d.ts"
    },
    "./zod": {
      "bun": "./src/zod.ts",
      "import": "./lib/zod.js",
      "types": "./lib/types/zod.d.ts"
    },
    "./valibot": {
      "bun": "./src/valibot.ts",
      "import": "./lib/valibot.js",
      "types": "./lib/types/valibot.d.ts"
    },
    "./arktype": {
      "bun": "./src/arktype.ts",
      "import": "./lib/arktype.js",
      "types": "./lib/types/arktype.d.ts"
    }
  },
  "scripts": {
    "build": "vl_rolldown_build",
    "dev": "vl_rolldown_build-watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@pyreon/form": ">=0.0.1"
  },
  "peerDependenciesMeta": {
    "zod": { "optional": true },
    "valibot": { "optional": true },
    "arktype": { "optional": true }
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.3",
    "@pyreon/core": "file:../../../pyreon/packages/core",
    "@pyreon/form": "file:../form",
    "@pyreon/reactivity": "file:../../../pyreon/packages/reactivity",
    "@pyreon/runtime-dom": "file:../../../pyreon/packages/runtime-dom",
    "zod": "^4.3.6",
    "valibot": "^1.2.0",
    "arktype": "^2.2.0"
  }
}
