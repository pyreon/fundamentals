{
  "name": "pyreon-fundamentals",
  "private": true,
  "workspaces": ["packages/*", "examples/*"],
  "scripts": {
    "build": "bun run --filter='@pyreon/*' build",
    "dev": "bun run --filter='@pyreon/*' dev",
    "test": "bun run --filter='@pyreon/*' test",
    "lint": "biome lint ./packages/",
    "format": "biome format --write ./packages/",
    "check": "biome check --write ./packages/",
    "typecheck": "bun run --filter='@pyreon/*' typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitus-labs/tools-lint": "1.14.0",
    "@vitus-labs/tools-rolldown": "1.14.0",
    "@vitus-labs/tools-typescript": "1.14.0",
    "@vitus-labs/tools-vitest": "1.14.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
