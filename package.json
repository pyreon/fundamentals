{
  "name": "pyreon-fundamentals",
  "private": true,
  "workspaces": ["packages/*", "examples/*"],
  "scripts": {
    "build": "bun run --filter='@pyreon/*' build",
    "dev": "bun run --filter='@pyreon/*' dev",
    "test": "bun run --filter='@pyreon/*' test",
    "lint": "biome lint ./packages/",
    "format": "biome format --write ./packages/",
    "check": "biome check --write ./packages/",
    "typecheck": "bun run --filter='@pyreon/*' typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run build && bun run scripts/publish.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitus-labs/tools-lint": "1.15.4",
    "@vitus-labs/tools-rolldown": "1.15.4",
    "@vitus-labs/tools-typescript": "1.15.4",
    "@vitus-labs/tools-vitest": "1.15.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@pyreon/core": ">=0.7.0 <0.8.0",
    "@pyreon/reactivity": ">=0.7.0 <0.8.0",
    "@pyreon/runtime-dom": ">=0.7.0 <0.8.0",
    "@pyreon/typescript": ">=0.7.0 <0.8.0"
  }
}
